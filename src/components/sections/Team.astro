---
import { Globe } from "@lucide/astro";

const team = [
  {
    name: "Álvaro",
    role: "Ing. Civil en Informática",
    description:
      "Apasionado por la tecnología, me especializo en desarrollo web y móvil, creando soluciones innovadoras que impulsan el éxito de nuestros clientes.",
    image: "/alvaro-gluonex.webp",
    linkedin: "https://www.linkedin.com/in/alvaroloyola/",
    portfolio: "https://alvaroloyola.dev",
  },
  {
    name: "Alejandro",
    role: "Ing. Civil en Informática",
    description:
      "Diseño aplicaciones full stack equilibrando un alto rendimiento con una experiencia de usuario intuitiva, contribuyendo directamente a la entrega de valor real.",
    image: "/ale-gluonex.webp",
    linkedin: "https://www.linkedin.com/in/alejandroyaneez/",
    portfolio: "https://alejandroyanez.dev",
  },
  {
    name: "Anaís",
    role: "Ing. Civil en Informática",
    description:
      "Diseño la arquitectura del software y optimizo el rendimiento. Me aseguro de que la base técnica de cada proyecto sea robusta, segura y escalable.",
    image: "/anais-gluonex.webp",
    linkedin: "https://www.linkedin.com/in/anaissaldiasn/",
  },
  {
    name: "Rocío",
    role: "Ing. Civil en Informática",
    description:
      "Desarrollo de software y diseño de interfaces. Combinando código escalable con un apartado visual atractivo.",
    image: "/rocio-gluonex.webp",
    linkedin: "https://www.linkedin.com/in/rociorivastp/",
    portfolio: "https://rociorivas.dev",
  },
];
---

<section id="team" class="py-20 md:py-32 bg-surface relative overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12 relative z-10">
    <div class="mb-16 md:mb-20 animate-on-scroll">
      <span
        class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold tracking-widest text-xs uppercase mb-6"
      >
        Sobre Nosotros
      </span>
      <h2
        class="text-3xl md:text-5xl font-bold text-base-content tracking-tight"
      >
        El equipo detrás de la magia.
      </h2>
    </div>

    <div
      class="flex flex-col md:flex-row w-full h-200 md:h-125 gap-3 animate-on-scroll"
    >
      {
        team.map((member) => (
          <div
            tabindex="0"
            class="group relative flex-1 hover:flex-4 focus-within:flex-4 transition-[flex] duration-700 ease-out overflow-hidden rounded-2xl cursor-pointer"
          >
            <div class="absolute inset-0 flex justify-center items-center pointer-events-none">
              <img
                src={member.image}
                alt={member.name}
                class="h-full w-auto max-w-none grayscale group-hover:grayscale-0 group-focus-within:grayscale-0 transition-colors duration-700 ease-in-out"
              />
            </div>

            <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-black/10 opacity-80 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />

            <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
              <h3 class="text-white text-2xl md:text-3xl font-bold tracking-tight mb-1 whitespace-nowrap pointer-events-none">
                {member.name}
              </h3>

              <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] group-focus-within:grid-rows-[1fr] transition-[grid-template-rows] duration-500 ease-out">
                <div class="overflow-hidden">
                  <p class="text-primary font-bold text-xs md:text-sm uppercase tracking-widest mt-2 mb-3 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-500 delay-150 pointer-events-none">
                    {member.role}
                  </p>
                  <p class="text-white/80 text-sm md:text-base leading-relaxed opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-500 delay-200 pointer-events-none">
                    {member.description}
                  </p>

                  <div class="flex items-center gap-4 mt-5 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-500 delay-300">
                    {member.linkedin && (
                      <a
                        href={member.linkedin}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-2 bg-white/10 hover:bg-primary/20 hover:text-primary rounded-full text-white backdrop-blur-sm transition-all duration-300"
                        aria-label={`LinkedIn de ${member.name}`}
                      >
                        <svg
                          class="w-5 h-5"
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                        </svg>
                      </a>
                    )}
                    {member.portfolio && (
                      <a
                        href={member.portfolio}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-2 bg-white/10 hover:bg-primary/20 hover:text-primary rounded-full text-white backdrop-blur-sm transition-all duration-300"
                        aria-label={`Portafolio de ${member.name}`}
                      >
                        <Globe class="w-5 h-5" />
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
