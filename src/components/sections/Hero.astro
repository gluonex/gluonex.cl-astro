---

---

<section
  id="hero"
  class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-surface"
>
  <div class="absolute inset-0 z-0 pointer-events-none">
    <!-- Dots pattern -->
    <div
      class="absolute inset-0 bg-[radial-gradient(var(--color-primary)_1px,transparent_1px)] bg-size-[40px_40px] opacity-[0.05]"
    >
    </div>

    <!-- CSS-only orbs: colores desde variables del tema, sin hex hardcodeados -->
    <!-- Opacidades distintas por modo: light ~12%, dark ~32% (fondo oscuro amplifica el brillo) -->
    <div class="hero-bg-orb hero-bg-orb-1"></div>
    <div class="hero-bg-orb hero-bg-orb-2"></div>
    <div class="hero-bg-orb hero-bg-orb-3"></div>
    <div class="hero-bg-orb hero-bg-orb-4"></div>
  </div>

  <div
    class="container mx-auto px-6 lg:px-12 relative z-10 flex flex-col items-center text-center"
  >
    <div class="max-w-4xl flex flex-col items-center animate-on-scroll">
      <span
        class="inline-block bg-primary/10 text-primary px-4 py-1.5 rounded-full text-[10px] md:text-xs font-bold tracking-widest uppercase mb-6"
      >
        Agencia de Servicios TI
      </span>
      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-base-content leading-[1.05] tracking-tighter mb-8"
      >
        Soluciones de alto nivel
        <span
          class="bg-linear-to-r from-secondary to-info dark:from-primary dark:to-primary/50 bg-clip-text text-transparent pr-2 inline-block"
        >
          a tu alcance.</span
        >
      </h1>
      <p
        class="text-base md:text-xl text-base-content/70 max-w-2xl leading-relaxed mb-12 font-medium"
      >
        Impulsa tu pyme o startup con desarrollo de software a medida.
        Combinamos diseño atractivo y tecnología escalable ajustados a tu
        presupuesto.
      </p>
      <div class="flex flex-wrap justify-center gap-6">
        <a
          href="#contact"
          class="dark:text-accent-content text-base relative group bg-secondary text-white px-6 md:px-10 py-3 md:py-5 rounded-xl md:text-lg font-bold shadow-2xl hover:scale-105 transition-transform dark:bg-primary"
        >
          <span class="relative z-10 dark:text-dark">Cotizar Proyectos</span>
        </a>
        <a
          href="#services"
          class="relative group bg-surface border border-base-300 hover:border-transparent px-6 md:px-10 py-3 md:py-5 rounded-xl text-base md:text-lg font-bold transition-all duration-500 text-secondary dark:text-primary"
        >
          <div
            class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
            style="padding:2px;background:linear-gradient(to bottom right, var(--color-primary), var(--color-secondary));-webkit-mask:linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude"
          >
          </div>

          <span class="relative z-10">Conocer Servicios</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* ── Hero background orbs ─────────────────────────────────────────────────
     Light mode: secondary (azul grisáceo #475a68) a ~22-28% — visible sobre blanco.
     Dark mode:  primary (gold #b8a982) a ~27-34% — warm glow sobre fondo oscuro.
     color-mix() usa las variables del tema: sin hex hardcodeados.
  ───────────────────────────────────────────────────────────────────────── */

  .hero-bg-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    /* Borde sutil por defecto para el modo claro */
    border: 1px solid
      color-mix(in srgb, var(--color-secondary) 40%, transparent);
  }

  /* Orb 1 — grande, inferior-izquierda */
  .hero-bg-orb-1 {
    width: 680px;
    height: 680px;
    bottom: -15%;
    left: -8%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-secondary) 50%, transparent) 0%,
      /* Mantiene el color sólido */ transparent 68%
        /* Transición rápida = borde más duro */
    );
    filter: blur(50px); /* Blur muy reducido */
    animation: hero-orb-pulse 8s ease-in-out infinite;
  }

  /* Orb 2 — pequeño, centro-izquierda */
  .hero-bg-orb-2 {
    width: 260px;
    height: 260px;
    top: 42%;
    left: 24%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-secondary) 50%, transparent) 0%,
      transparent 68%
    );
    filter: blur(50px);
    animation: hero-orb-pulse 7s ease-in-out infinite alternate;
  }

  /* Orb 3 — grande, superior-derecha */
  .hero-bg-orb-3 {
    width: 560px;
    height: 560px;
    top: -12%;
    right: 14%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-secondary) 50%, transparent) 0%,

      transparent 68%
    );
    filter: blur(50px);
    animation: hero-orb-pulse 10s ease-in-out infinite alternate-reverse;
  }

  /* Orb 4 — muy grande, derecha (mezcla de colores) */
  .hero-bg-orb-4 {
    width: 760px;
    height: 760px;
    top: 22%;
    right: -12%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-secondary) 50%, transparent) 0%,

      transparent 68%
    );
    filter: blur(50px);
    animation: hero-orb-pulse 12s ease-in-out infinite;
  }

  /* ── Dark mode: opacidades más altas (fondo oscuro = colores más vívidos) */

  .dark .hero-bg-orb-1 {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-primary) 34%, transparent) 0%,

      transparent 70%
    );
  }

  .dark .hero-bg-orb-2 {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-primary) 27%, transparent) 0%,

      transparent 70%
    );
  }

  .dark .hero-bg-orb-3 {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-primary) 30%, transparent) 0%,

      transparent 70%
    );
  }

  .dark .hero-bg-orb-4 {
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-secondary) 24%, transparent) 0%,

      color-mix(in srgb, var(--color-primary) 19%, transparent) 45%,

      transparent 70%
    );
  }

  /* Animación suave de respiración */
  @keyframes hero-orb-pulse {
    0%,
    100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }
</style>
