---
import { Rocket } from "@lucide/astro";
---

<a
  href="/landing"
  id="premium-floating-badge"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 md:bottom-8 md:left-8 md:translate-x-0 z-50 group flex items-center"
>
  <!-- ============================================== -->
  <!-- 1. Glow Ambiental (Sombra de luz proyectada)   -->
  <!-- ============================================== -->
  <div
    class="absolute inset-0 bg-secondary/30 dark:bg-primary/30 blur-xl rounded-full group-hover:scale-125 group-hover:bg-secondary/50 dark:group-hover:bg-primary/50 transition-all duration-500 opacity-70"
  >
  </div>

  <!-- ============================================== -->
  <!-- 2. La Píldora de Cristal (Glassmorphism)       -->
  <!-- ============================================== -->
  <div
    class="relative flex items-center gap-3 px-2 py-2 pr-6 bg-white/70 dark:bg-base-100/70 backdrop-blur-xl border border-secondary/30 dark:border-primary/30 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.12)] group-hover:border-secondary/60 dark:group-hover:border-primary/60 group-hover:-translate-y-1 transition-all duration-300 overflow-hidden"
  >
    <!-- Shimmer Effect (Reflejo de luz al hacer hover) -->
    <div
      class="absolute inset-0 -translate-x-full group-hover:translate-x-full bg-linear-to-r from-transparent via-white/50 dark:via-white/10 to-transparent transition-transform duration-1000 ease-in-out"
    >
    </div>

    <!-- Contenedor del Icono animado -->
    <div
      class="relative flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-full bg-secondary dark:bg-primary shrink-0 transition-transform duration-300 group-hover:scale-105 shadow-inner"
    >
      <Rocket
        class="w-4 h-4 md:w-5 md:h-5 text-white dark:text-base-100 group-hover:animate-rocket-shake"
      />

      <!-- Mini radar/pulso saliendo del icono -->
      <div
        class="absolute inset-0 rounded-full border border-secondary dark:border-primary animate-ping opacity-20"
      >
      </div>
    </div>

    <!-- Textos y Estado -->
    <div class="flex flex-col justify-center">
      <div class="flex items-center gap-1.5 mb-0.5">
        <!-- Indicador de estado (Punto de luz) -->
        <span class="relative flex h-1.5 w-1.5">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"
          ></span>
          <span
            class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"
          ></span>
        </span>
        <span
          class="text-[9px] font-bold uppercase tracking-widest text-base-content/50 leading-none mt-px"
        >
          Cupos Disponibles
        </span>
      </div>

      <span
        class="font-bold text-sm md:text-base text-base-content whitespace-nowrap tracking-tight leading-none group-hover:text-secondary dark:group-hover:text-primary transition-colors"
      >
        ¡Lanza tu Página!
      </span>
    </div>
  </div>
</a>

<style>
  /* Animación sutil para el cohete en hover */
  @keyframes rocket-shake {
    0%,
    100% {
      transform: translateY(0) rotate(0);
    }
    25% {
      transform: translateY(-2px) rotate(-5deg);
    }
    50% {
      transform: translateY(0) rotate(5deg);
    }
    75% {
      transform: translateY(-2px) rotate(-5deg);
    }
  }
  .animate-rocket-shake {
    animation: rocket-shake 0.5s ease-in-out infinite;
  }
</style>

<script>
  import { animate } from "motion";

  // Entrada elegante y profesional (Fade in + Slide Up)
  const badge =
    typeof document !== "undefined"
      ? document.getElementById("premium-floating-badge")
      : null;

  if (badge) {
    (animate as any)(
      badge as any,
      { y: [50, 0], opacity: [0, 1] },
      {
        duration: 0.8,
        delay: 1.2,
        easing: [0.22, 1, 0.36, 1], // Easing de "resorte" suave
      }
    );
  }
</script>
