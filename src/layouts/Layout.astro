---
import "../styles/globals.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import FloatingServiceBadge from "../components/FloatingServiceBadge.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GluonEX | Agencia de Servicios TI",
  description = "Soluciones de alto nivel a tu alcance. Desarrollo de software a medida para pymes y startups en Chile.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/world.webp" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://gluonex.cl" />
    <link rel="canonical" href="https://gluonex.cl" />
    <link
      rel="preload"
      href="/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
  </head>
  <body class="min-h-full flex flex-col">
    <slot />
    <FloatingServiceBadge />
    <ThemeToggle />
  </body>
</html>
