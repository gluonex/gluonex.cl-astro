---
import { Menu, X } from "@lucide/astro";
---

<header
  class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-xl border-b border-base-300/50 shadow-[0_4px_40px_-15px_rgba(0,0,0,0.05)]"
>
  <nav
    class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between py-5"
  >
    <a href="/" class="relative z-50">
      <img
        src="/logo.webp"
        alt="GluonEX Logo"
        width="159"
        height="40"
        class="h-10 w-auto"
      />
    </a>

    <div class="hidden lg:flex items-center space-x-8 xl:space-x-12">
      <a
        href="#hero"
        class="text-base-content hover:text-primary font-semibold tracking-tight transition-colors"
        >Inicio</a
      >
      <a
        href="#about"
        class="text-base-content hover:text-primary font-semibold tracking-tight transition-colors"
        >Nosotros</a
      >
      <a
        href="#services"
        class="text-base-content hover:text-primary font-semibold tracking-tight transition-colors"
        >Servicios</a
      >
      <a
        href="#contact"
        class="text-base-content hover:text-primary font-semibold tracking-tight transition-colors"
        >Contáctanos</a
      >
    </div>

    <button
      id="menu-toggle"
      class="lg:hidden relative z-50 text-base-content hover:text-primary transition-colors p-2"
      aria-label="Alternar menú"
    >
      <Menu id="icon-open" class="w-7 h-7" />
      <X id="icon-close" class="w-7 h-7 hidden" />
    </button>
  </nav>
</header>

<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 top-18.25 bg-white z-40 transform translate-x-full transition-transform duration-300 ease-out"
>
  <div class="flex flex-col items-center justify-start pt-12 space-y-8 px-6">
    <a
      href="#hero"
      class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
      >Inicio</a
    >
    <a
      href="#about"
      class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
      >Nosotros</a
    >
    <a
      href="#services"
      class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
      >Servicios</a
    >
    <a
      href="#contact"
      class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
      >Contáctanos</a
    >
  </div>
</div>

<script is:inline>
  (function () {
    var toggle = document.getElementById("menu-toggle");
    var menu = document.getElementById("mobile-menu");
    var iconOpen = document.getElementById("icon-open");
    var iconClose = document.getElementById("icon-close");
    var isOpen = false;

    function updateMenu(open) {
      isOpen = open;
      if (open) {
        menu.classList.remove("translate-x-full");
        menu.classList.add("translate-x-0");
        iconOpen.classList.add("hidden");
        iconClose.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      } else {
        menu.classList.add("translate-x-full");
        menu.classList.remove("translate-x-0");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
        document.body.style.overflow = "";
      }
    }

    toggle.addEventListener("click", function () {
      updateMenu(!isOpen);
    });

    document.querySelectorAll(".mobile-nav-link").forEach(function (link) {
      link.addEventListener("click", function () {
        updateMenu(false);
      });
    });
  })();
</script>
