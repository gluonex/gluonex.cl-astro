---
import { Clock, Code, Globe, Search } from "@lucide/astro";

const metrics = [
  {
    icon: Clock,
    value: "7-10",
    label: "días hábiles",
  },
  {
    icon: Code,
    value: "100%",
    label: "código propio",
  },
  {
    icon: Globe,
    value: "$0",
    label: "hosting incluido",
  },
  {
    icon: Search,
    value: "100%",
    label: "SEO optimizado",
  },
] as const;

const whatsappHref =
  "https://wa.me/56973789128?text=Hola%20GluonEX%2C%20quiero%20cotizar%20una%20Landing%20Page.";
---

<section
  id="hero-landing"
  class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-surface"
>
  <!-- Background layer -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <!-- Dot grid -->
    <div
      class="absolute inset-0 bg-[radial-gradient(var(--color-primary)_1px,transparent_1px)] bg-size-[40px_40px] opacity-[0.05]"
    >
    </div>

    <!-- Orb 1 -->
    <div
      class="absolute top-1/4 -left-32 w-96 h-96 bg-primary/10 rounded-full blur-[100px] animate-[pulse_6s_ease-in-out_infinite]"
    >
    </div>

    <!-- Orb 2 -->
    <div
      class="absolute bottom-1/4 -right-32 w-160 h-160 bg-secondary/10 rounded-full blur-[120px] animate-[pulse_8s_ease-in-out_infinite_alternate]"
    >
    </div>
  </div>

  <!-- Content -->
  <div
    class="container mx-auto px-6 lg:px-12 relative z-10 flex flex-col items-center text-center"
  >
    <div class="max-w-4xl flex flex-col items-center animate-on-scroll">
      <!-- Badge -->
      <span
        class="inline-flex items-center backdrop-blur-md bg-white/60 dark:bg-base-100/60 border border-base-300/50 px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase text-primary mb-6"
      >
        Sin promesas vacías
      </span>

      <!-- Headline -->
      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-base-content leading-[1.05] tracking-tighter mb-8"
      >
        Tu web<span
          class="bg-linear-to-r from-secondary to-info bg-clip-text text-transparent pr-2 inline-block"
        >
          publicada.</span
        >
      </h1>

      <!-- Subtitle -->
      <p
        class="text-base md:text-xl text-base-content/70 max-w-2xl leading-relaxed mb-10 font-medium"
      >
        Diseño web a medida para tu negocio. Sin templates, sin letra chica.
        Código 100% tuyo, publicada en 7-10 días hábiles.
      </p>

      <!-- Metrics grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12 w-full max-w-3xl">
        {
          metrics.map(({ icon: Icon, value, label }) => (
            <div class="relative bg-white/60 dark:bg-base-100/60 backdrop-blur-xl border border-base-300/50 rounded-2xl p-6 text-center group hover:border-primary/30 transition-all duration-500">
              <!-- Hover glow -->
              <div class="absolute inset-0 rounded-2xl bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl pointer-events-none" />

              <!-- Icon -->
              <div class="relative z-10 w-8 h-8 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                <Icon class="w-4 h-4 text-primary" />
              </div>

              <!-- Value -->
              <p class="relative z-10 text-3xl md:text-4xl font-bold text-secondary mb-1">
                {value}
              </p>

              <!-- Label -->
              <p class="relative z-10 text-xs text-base-content/50 uppercase tracking-wider font-medium">
                {label}
              </p>
            </div>
          ))
        }
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap justify-center gap-6">
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-secondary text-white px-6 md:px-10 py-3 md:py-5 rounded-xl font-bold shadow-2xl hover:scale-105 transition-transform text-base md:text-lg"
        >
          Cotizar Ahora
        </a>

        <a
          href="#pricing"
          class="relative group bg-surface border border-base-300 hover:border-transparent px-6 md:px-10 py-3 md:py-5 rounded-xl font-bold transition-all duration-500 text-secondary text-base md:text-lg"
        >
          <!-- Gradient border on hover -->
          <div
            class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
            style="padding:2px;background:linear-gradient(to bottom right, var(--color-primary), var(--color-secondary));-webkit-mask:linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude"
          >
          </div>
          <span class="relative z-10">Ver Detalles</span>
        </a>
      </div>
    </div>
  </div>
</section>
