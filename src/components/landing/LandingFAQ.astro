---
import { Plus } from "@lucide/astro";

const faqs = [
  {
    q: "¿Cuánto tarda el proceso completo?",
    a: "Entre 7 y 10 días hábiles desde el kickoff hasta la publicación final. Esto incluye diseño, desarrollo, revisiones y entrega con dominio y hosting activos.",
  },
  {
    q: "¿Qué pasa si no me gusta el diseño?",
    a: "Hacemos revisiones hasta conformidad: iteramos y ajustamos hasta que el resultado te convenza al 100%. No avanzamos a la siguiente etapa sin tu aprobación explícita.",
  },
  {
    q: "¿El código es realmente mío?",
    a: "Sí, al 100%. Te entregamos el repositorio completo con todo el código fuente. No dependes de ninguna plataforma cerrada ni de nosotros para hacer cambios.",
  },
  {
    q: "¿Qué pasa después del primer año con el hosting y dominio?",
    a: "El dominio .cl lo puedes renovar tú mismo por $10.000 aprox. El hosting en Cloudflare Pages o Netlify es gratuito. La página es tuya, siempre. Sin mantenciones.",
  },
  {
    q: "¿Puedo editarla después?",
    a: "Sí. Si está construida con tecnología moderna, puedes editarla tú mismo o contratarnos para cambios puntuales. Sin dependencia absoluta. El código es tuyo.",
  },
  {
    q: "¿Puedo cambiar de proveedor?",
    a: "No lo recomendamos, pero sí. Entregamos la página alojada en un hosting gratuito y el código fuente completo. Puedes migrar a cualquier alternativa cuando quieras. No te amarramos absolutamente nada.",
  },
  {
    q: "¿Facturan con IVA?",
    a: "Sí. Somos empresa formal. Emitimos factura con IVA desglosado. El precio que ves es + IVA.",
  },
  {
    q: "¿Puedo crear una tienda online (E-Commerce)?",
    a: "No. Este plan está diseñado para marcas y negocios que buscan aumentar su visibilidad, fortalecer su presencia digital y captar nuevos clientes. Las tiendas E-Commerce requieren funcionalidades más avanzadas, como catálogo de productos, carrito de compras, pasarelas de pago y gestión de pedidos. Si necesitas una solución de este tipo, podemos prepararte una cotización personalizada. Contáctanos para más información.",
  },
  {
    q: "¿Puedo agregar más páginas después?",
    a: "Sí. Cada landing adicional tiene un precio preferencial. Cuéntanos qué necesitas y te damos una cotización cerrada.",
  },
  {
    q: "¿Cómo empezamos?",
    a: "Escríbenos por WhatsApp o email. En menos de 24 horas coordinamos el kickoff y comenzamos el proceso.",
  },
];
---

<section id="faq" class="bg-base-200 py-24 md:py-32 relative overflow-hidden">
  <!-- ========================== -->
  <!-- Background Layer           -->
  <!-- ========================== -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute inset-0 opacity-[0.015] bg-[url(/noise.svg)] dark:opacity-[0.03]"></div>
    <div class="absolute top-0 inset-x-0 h-px bg-linear-to-r from-transparent via-base-content/10 to-transparent"></div>
    <div class="absolute bottom-0 right-0 w-200 h-200 bg-secondary/5 dark:bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>
  </div>

  <!-- ========================== -->
  <!-- Main Content               -->
  <!-- ========================== -->
  <div class="container mx-auto px-6 lg:px-12 relative z-10">

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">

      <!-- ==================================== -->
      <!-- LADO IZQUIERDO: Sticky Header        -->
      <!-- ==================================== -->
      <div class="lg:col-span-5 lg:sticky lg:top-32 flex flex-col pt-4 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-black text-base-content tracking-tighter leading-[0.95] mb-6">
          Preguntas <br />
          <span class="text-transparent bg-clip-text bg-linear-to-r from-base-content to-base-content/80">
            Honestas.
          </span>
        </h2>

        <p class="text-lg text-base-content/60 font-medium mb-8 max-w-md">
          Respuestas claras. Si tienes una duda técnica o comercial que no esté en esta lista, escríbenos directamente.
        </p>
      </div>

      <!-- ==================================== -->
      <!-- LADO DERECHO: Acordeón Minimalista   -->
      <!-- ==================================== -->
      <div class="lg:col-span-7 border-t border-base-content/10">
        <div class="flex flex-col">
          {
            faqs.map((faq, index) => {
              const num = (index + 1).toString().padStart(2, '0');
              return (
                <div class="faq-item group border-b border-base-content/10 transition-colors duration-300 hover:bg-surface/30 dark:hover:bg-base-100/30">
                  <button
                    class="faq-toggle w-full flex items-start lg:items-center justify-between py-6 lg:py-8 pr-4 text-left cursor-pointer"
                    aria-expanded="false"
                  >
                    <div class="flex items-start lg:items-center gap-4 lg:gap-8 pr-6">
                      <!-- Numeración Técnica -->
                      <span class="faq-number font-mono text-sm font-bold text-base-content/30 group-hover:text-secondary dark:group-hover:text-primary transition-colors duration-300 mt-1 lg:mt-0">
                        {num}
                      </span>
                      <!-- Título de la Pregunta -->
                      <h3 class="faq-question text-xl lg:text-2xl font-bold text-base-content tracking-tight group-hover:text-secondary dark:group-hover:text-primary transition-colors duration-300">
                        {faq.q}
                      </h3>
                    </div>

                    <!-- Icono Plus (Gira a 'X' vía JS) -->
                    <div class="relative w-6 h-6 shrink-0 mt-1 lg:mt-0 flex items-center justify-center">
                      <Plus class="faq-icon w-6 h-6 text-base-content/40 group-hover:text-secondary dark:group-hover:text-primary transition-all duration-500" stroke-width={2} />
                    </div>
                  </button>

                  <!-- Contenedor de la Respuesta -->
                  <div
                    class="faq-answer overflow-hidden transition-all duration-500 ease-in-out"
                    style="max-height: 0; opacity: 0;"
                  >
                    <p class="pb-8 pl-12 lg:pl-18 text-base lg:text-lg text-base-content/70 leading-relaxed font-medium max-w-2xl">
                      {faq.a}
                    </p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ========================== -->
<!-- Lógica JavaScript          -->
<!-- ========================== -->
<script is:inline>
  document.querySelectorAll(".faq-toggle").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var item = btn.closest(".faq-item");
      var answer = item.querySelector(".faq-answer");
      var icon = item.querySelector(".faq-icon");
      var question = item.querySelector(".faq-question");
      var number = item.querySelector(".faq-number");
      var isOpen = btn.getAttribute("aria-expanded") === "true";

      // 1. Cerrar todos los demás items (Acordeón único)
      document.querySelectorAll(".faq-item").forEach(function (other) {
        if (other !== item) {
          var otherBtn = other.querySelector(".faq-toggle");
          var otherAnswer = other.querySelector(".faq-answer");
          var otherIcon = other.querySelector(".faq-icon");
          var otherQuestion = other.querySelector(".faq-question");
          var otherNumber = other.querySelector(".faq-number");

          otherBtn.setAttribute("aria-expanded", "false");

          // Cerrar contenedor
          otherAnswer.style.maxHeight = "0";
          otherAnswer.style.opacity = "0";

          // Resetear icono (Plus)
          if (otherIcon) otherIcon.style.transform = "rotate(0deg)";

          // Resetear colores
          if(otherQuestion) otherQuestion.classList.remove("text-secondary", "dark:text-primary");
          if(otherNumber) otherNumber.classList.remove("text-secondary", "dark:text-primary");
          if(otherIcon) otherIcon.classList.remove("text-secondary", "dark:text-primary");
        }
      });

      // 2. Alternar el actual
      btn.setAttribute("aria-expanded", String(!isOpen));

      if (isOpen) {
        // Cerrando...
        answer.style.maxHeight = "0";
        answer.style.opacity = "0";
        if (icon) icon.style.transform = "rotate(0deg)";

        // Quitar clases de color activo
        question.classList.remove("text-secondary", "dark:text-primary");
        number.classList.remove("text-secondary", "dark:text-primary");
        icon.classList.remove("text-secondary", "dark:text-primary");

      } else {
        // Abriendo...
        answer.style.maxHeight = answer.scrollHeight + "px";
        answer.style.opacity = "1";
        // Gira 45 grados (Plus -> X)
        if (icon) icon.style.transform = "rotate(45deg)";

        // Añadir clases de color activo (Respeta la regla light/dark)
        question.classList.add("text-secondary", "dark:text-primary");
        number.classList.add("text-secondary", "dark:text-primary");
        icon.classList.add("text-secondary", "dark:text-primary");
      }
    });
  });
</script>

<style is:global>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out both;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
