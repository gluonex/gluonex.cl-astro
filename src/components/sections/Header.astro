---
import { Menu, X } from "@lucide/astro";
---

<header
  class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-xl border-b border-base-300/50 shadow-[0_4px_40px_-15px_rgba(0,0,0,0.05)]"
>
  <nav
    class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between py-5"
  >
    <a href="/" class="z-10">
      <img src="/logo.png" alt="GluonEX Logo" class="h-10 w-auto" />
    </a>

    <div class="hidden lg:flex items-center space-x-8 xl:space-x-12">
      <a
        href="#hero"
        class="text-secondary hover:text-primary font-semibold tracking-tight transition-colors"
        >Inicio</a
      >
      <a
        href="#about"
        class="text-secondary hover:text-primary font-semibold tracking-tight transition-colors"
        >Nosotros</a
      >
      <a
        href="#services"
        class="text-secondary hover:text-primary font-semibold tracking-tight transition-colors"
        >Servicios</a
      >
      <a
        href="#contact"
        class="text-secondary hover:text-primary font-semibold tracking-tight transition-colors"
        >Contáctanos</a
      >
    </div>

    <button
      id="menu-toggle"
      class="lg:hidden text-base-content hover:text-primary transition-colors z-10"
      aria-label="Alternar menú"
    >
      <Menu class="w-7 h-7 menu-open" />
      <X class="w-7 h-7 menu-close hidden" />
    </button>

    <div
      id="mobile-menu"
      class="hidden lg:hidden fixed inset-0 bg-white/95 backdrop-blur-xl z-40"
    >
      <div class="flex flex-col items-center justify-center h-full space-y-8">
        <a
          href="#hero"
          class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
          >Inicio</a
        >
        <a
          href="#about"
          class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
          >Nosotros</a
        >
        <a
          href="#services"
          class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
          >Servicios</a
        >
        <a
          href="#contact"
          class="text-2xl text-base-content hover:text-primary font-semibold tracking-tight transition-colors mobile-nav-link"
          >Contáctanos</a
        >
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuOpen = toggle?.querySelector(".menu-open");
  const menuClose = toggle?.querySelector(".menu-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    menuOpen?.classList.toggle("hidden");
    menuClose?.classList.toggle("hidden");
    document.body.style.overflow = isOpen ? "hidden" : "";
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      menuOpen?.classList.remove("hidden");
      menuClose?.classList.add("hidden");
      document.body.style.overflow = "";
    });
  });
</script>
