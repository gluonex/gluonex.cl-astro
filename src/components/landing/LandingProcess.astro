---
import {
  Rocket,
  Palette,
  Layout,
  Code,
  RefreshCw,
  CheckCircle,
} from "@lucide/astro";

const steps = [
  {
    icon: Rocket,
    label: "Paso 01",
    title: "Kickoff",
    description:
      "Reunión inicial para entender tu negocio, tu marca y tus objetivos. Definimos el alcance exacto del proyecto.",
  },
  {
    icon: Palette,
    label: "Paso 02",
    title: "Dirección Creativa",
    description:
      "Proponemos la paleta de colores, tipografía y estilo visual. Aprobas antes de que comencemos a diseñar.",
  },
  {
    icon: Layout,
    label: "Paso 03",
    title: "Diseño",
    description:
      "Diseñamos los mockups completos de tu sitio. Iteras con nosotros hasta que el resultado te convenza.",
  },
  {
    icon: Code,
    label: "Paso 04",
    title: "Desarrollo",
    description:
      "Convertimos el diseño aprobado en código limpio, rápido y optimizado. Sin atajos, sin plantillas recicladas.",
  },
  {
    icon: RefreshCw,
    label: "Paso 05",
    title: "Revisiones",
    description:
      "Ajustes finales hasta que quedes 100% satisfecho. No hay límite de rondas.",
  },
  {
    icon: CheckCircle,
    label: "Paso 06",
    title: "Entrega",
    description:
      "Publicamos tu sitio, activamos el dominio y el hosting. Tu web está lista para recibir clientes.",
  },
] as const;
---

<section
  id="process"
  class="bg-base-200 py-20 md:py-32 relative overflow-hidden"
>
  <!-- Background orb -->
  <div
    class="absolute top-1/2 -left-32 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none"
  ></div>

  <!-- Section divider top -->
  <div
    class="absolute top-0 inset-x-0 h-px bg-linear-to-r from-transparent via-primary/20 to-transparent"
  ></div>

  <!-- Content -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16 md:mb-20 animate-on-scroll">
      <span
        class="text-primary font-bold tracking-widest text-xs uppercase mb-4 block"
      >
        El Proceso
      </span>
      <h2
        class="text-3xl md:text-5xl font-bold text-base-content tracking-tight"
      >
        De la Confirmación a la Entrega.
      </h2>
      <p class="text-base-content/50 text-sm md:text-base mt-4">
        6 pasos. Sin improvisación.
      </p>
    </div>

    <!-- Timeline -->
    <div class="max-w-4xl mx-auto relative">
      <!-- Vertical center line (desktop) / left line (mobile) -->
      <div
        class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-linear-to-b from-primary/10 via-primary/40 to-primary/10 md:-translate-x-1/2"
      ></div>

      <div class="space-y-8 md:space-y-12">
        {
          steps.map(({ icon: Icon, label, title, description }, index) => {
            const isLeft = index % 2 === 0;
            return (
              <div class="relative flex items-start animate-on-scroll">
                {/* Dot on the line */}
                <div class="absolute left-6 md:left-1/2 w-10 h-10 -translate-x-1/2 bg-base-200 border-2 border-primary rounded-full flex items-center justify-center z-10 shrink-0">
                  <Icon class="w-4 h-4 text-primary" />
                </div>

                {/* Card — left side (odd steps: 1, 3, 5) */}
                {isLeft ? (
                  <div class="ml-14 md:ml-0 md:w-[calc(50%-3rem)] md:mr-auto md:pr-8">
                    <div class="bg-surface border border-base-300 rounded-2xl p-6 shadow-sm hover:shadow-[0_0_30px_-5px_rgba(169,155,115,0.15)] transition-shadow duration-500">
                      <span class="text-primary font-bold text-xs uppercase tracking-widest">
                        {label}
                      </span>
                      <h3 class="text-xl font-bold text-base-content mt-2 mb-2">
                        {title}
                      </h3>
                      <p class="text-sm text-base-content/60 leading-relaxed">
                        {description}
                      </p>
                    </div>
                  </div>
                ) : (
                  /* Card — right side (even steps: 2, 4, 6) */
                  <div class="ml-14 md:ml-auto md:w-[calc(50%-3rem)] md:pl-8">
                    <div class="bg-surface border border-base-300 rounded-2xl p-6 shadow-sm hover:shadow-[0_0_30px_-5px_rgba(169,155,115,0.15)] transition-shadow duration-500">
                      <span class="text-primary font-bold text-xs uppercase tracking-widest">
                        {label}
                      </span>
                      <h3 class="text-xl font-bold text-base-content mt-2 mb-2">
                        {title}
                      </h3>
                      <p class="text-sm text-base-content/60 leading-relaxed">
                        {description}
                      </p>
                    </div>
                  </div>
                )}
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
