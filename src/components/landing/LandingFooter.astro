---
import { ArrowLeft } from "@lucide/astro";
---

<footer class="relative bg-neutral border-t border-white/10 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 relative z-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo + tagline -->
      <div class="text-center md:text-left">
        <img
          src="/logo-texto-dark.webp"
          alt="GluonEX Logo"
          width="120"
          height="30"
          class="h-8 w-auto mb-3 mx-auto md:mx-0"
        />
        <p class="text-sm text-white/50">
          Arquitectos de tu crecimiento digital.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap justify-center gap-6 text-sm text-white/40">
        <a href="#hero-landing" class="hover:text-primary transition-colors"
          >Inicio</a
        >
        <a href="#pricing" class="hover:text-primary transition-colors"
          >Precios</a
        >
        <a href="#process" class="hover:text-primary transition-colors"
          >Proceso</a
        >
        <a href="#faq" class="hover:text-primary transition-colors">FAQ</a>
        <a
          href="/"
          class="hover:text-white transition-colors flex items-center gap-1"
        >
          <ArrowLeft class="w-3 h-3" />
          Página Principal
        </a>
      </nav>

      <!-- Contact -->
      <div class="text-center md:text-right text-sm text-white/40 space-y-1">
        <p>contacto@gluonex.cl</p>
        <p>+56 9 7378 9128</p>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/5 py-6 relative z-10">
    <div
      class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/30 tracking-wider"
    >
      <span>&copy; 2026 GLUONEX SPA. TODOS LOS DERECHOS RESERVADOS.</span>
      <a href="/" class="hover:text-white transition-colors">gluonex.cl</a>
    </div>
  </div>
</footer>
