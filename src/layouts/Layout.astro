---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GluonEX | Agencia de Servicios TI",
  description = "Soluciones de alto nivel a tu alcance. Desarrollo de software a medida para pymes y startups en Chile.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/world.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://gluonex.cl" />
    <link rel="canonical" href="https://gluonex.cl" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-full flex flex-col">
    <slot />
  </body>
</html>
